{
  "name": "joplin-note-categorization-plugin",
  "version": "1.0.0",
  "scripts": {
    "dist": "webpack --env joplin-plugin-config=buildMain && webpack --env joplin-plugin-config=buildExtraScripts && npm run copyAssets && webpack --env joplin-plugin-config=createArchive",
    "prepare": "npm run dist",
    "copyAssets": "node tools/copyAssets.js",
    "updateVersion": "webpack --env joplin-plugin-config=updateVersion",
    "update": "npm install -g generator-joplin && yo joplin --node-package-manager npm --update --force",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "ci": "npm run lint && npm run format:check && npm run dist"
  },
  "license": "MIT",
  "keywords": [
    "joplin-plugin"
  ],
  "files": [
    "publish"
  ],
  "devDependencies": {
    "@types/node": "^18.7.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "chalk": "^4.1.0",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.56.0",
    "fs-extra": "^10.1.0",
    "glob": "^8.0.3",
    "prettier": "^3.2.5",
    "tar": "^6.1.11",
    "ts-loader": "^9.3.1",
    "typescript": "^4.8.2",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "hdbscan-ts": "^1.0.17",
    "js-tiktoken": "^1.0.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "umap-js": "^1.4.0",
    "vectra": "^0.12.3"
  }
}
